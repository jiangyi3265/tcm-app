{
  "name": "hospital",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "node ./scripts/run-server.mjs spring-boot:run",
    "dev:full": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "build": "vite build",
    "build:server": "node ./scripts/run-server.mjs -DskipTests package",
    "build:full": "npm run build && npm run build:server",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "dayjs": "^1.11.19",
    "element-plus": "^2.13.2",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.29",
    "vue-i18n": "^9.14.0",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "mammoth": "^1.12.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
